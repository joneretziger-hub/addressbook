pipeline {
    agent none

    tools {
        maven "mymaven"
    }
    environment {
        DEV_SERVER_IP= 'ec2-user@184.73.138.213'
    }

    parameters {
        string(name: 'Env', defaultValue: 'Test', description: 'Environment to deploy the code')
        choice(name: 'APPVERSION', choices: ['1.1', '1.2', '1.3'], description: 'Pick something')
        booleanParam(name: 'excuteTests', defaultValue: true, description: 'decide to run')
    }

    stages {

        stage('Compile') {
            agent any
            steps {
                echo "Compile the code ${params.Env}"
                sh "mvn compile"
            }
        }

        stage('UnitTest') {
            when {
                expression {
                    params.excuteTests == true
                }
            }

            agent any

            steps {
                echo "Test the code"
                sh "mvn test"
            }

            post {
                always {
                    junit 'target/surefire-reports/*.xml'
                }
            }
        }

        stage('Package') {
            when {
                expression {
                    BRANCH_NAME == 'b1'
                }
            }
            agent any
            input {
                message "Select the version to deploy"
                ok "version selected"
                parameters {
                    choice(name: 'NEWAPP', choices: ['1.1', '1.2', '1.3'], description: 'Pick something')
                }
            }

            steps {
                script {
                sshagent (['slave']) {
                 echo "Package the code ${params.APPVERSION}"
                sh "scp -o StrictHostKeyChecking=no server-script.sh  ${DEV_SERVER_IP}:/home/ec2-user"
                sh "ssh -o StrictHostKeyChecking=no ${DEV_SERVER_IP} 'bash ~/script-server.sh"
                }   
            }
        }
    }
}